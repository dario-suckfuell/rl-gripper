<?xml version="1.0"?>
<robot name="container_box">
  <link name="container">
    <visual>
      <geometry>
        <box size="0.3 0.3 0.1"/>
      </geometry>
      <origin xyz="0 0 0.05"/>
      <material name="dark_brown">
        <color rgba="0.396 0.263 0.129 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.3 0.3 0.1"/>
      </geometry>
      <origin xyz="0 0 0.05"/>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0.05"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>
  <gazebo reference="container">
    <material>Gazebo/DarkBrown</material>
  </gazebo>
</robot>

